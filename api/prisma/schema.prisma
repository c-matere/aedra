generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis, vector]
}

/// This table contains check constraints and requires additional setup for migrations.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)

  @@ignore
}

/// A user who can log in to the Aedra platform.
/// Super Admins have no companyId (they are platform-level).
/// Company Admins & Staff belong to exactly one Company.
model User {
  id                     String               @id @default(uuid())
  email                  String               @unique
  password               String
  firstName              String
  lastName               String
  phone                  String?
  role                   UserRole             @default(COMPANY_STAFF)
  isActive               Boolean              @default(true)
  companyId              String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  deletedAt              DateTime?
  permissions            String[]             @default([])
  language               String               @default("en")
  chatHistories          ChatHistory[]
  maintenanceAssignments MaintenanceRequest[]
  todos                  TodoItem[]
  company                Company?             @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([role])
  @@index([deletedAt])
}

/// A property management company operating in Mombasa.
/// This is the tenant isolation boundary — all business data is scoped here.
model Company {
  id                    String                 @id @default(uuid())
  name                  String
  email                 String?
  phone                 String?
  address               String?
  logo                  String?
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  waAccessToken         String?
  waBusinessAccountId   String?
  waOwnerPhone          String?
  waPhoneNumberId       String?
  waVerifyToken         String?
  authorizationRequests AuthorizationRequest[]
  chatHistories         ChatHistory[]
  documents             Document[]
  expenses              Expense[]
  incomes               Income[]
  invitations           Invitation[]
  landlords             Landlord[]
  maintenanceRequests   MaintenanceRequest[]
  properties            Property[]
  tenants               Tenant[]
  users                 User[]
  whatsappLogs          WhatsAppLog[]
  workflows             WorkflowInstance[]
}

/// A landlord / property owner managed by a Company.
/// A single landlord can own multiple properties.
model Landlord {
  id         String     @id @default(uuid())
  firstName  String
  lastName   String
  email      String?
  phone      String?
  idNumber   String?
  address    String?
  companyId  String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?
  language   String     @default("en")
  company    Company    @relation(fields: [companyId], references: [id])
  properties Property[]

  @@index([companyId])
  @@index([deletedAt])
}

/// A property (building, plot, estate) managed by a Company on behalf of a Landlord.
model Property {
  id                   String                 @id @default(uuid())
  name                 String
  address              String?
  propertyType         PropertyType           @default(RESIDENTIAL)
  description          String?
  latitude             Float?
  longitude            Float?
  landlordId           String?
  companyId            String
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  deletedAt            DateTime?
  commissionPercentage Float                  @default(0)
  semanticTags         String?
  embedding            Unsupported("vector")?
  documents            Document[]
  expenses             Expense[]
  incomes              Income[]
  leases               Lease[]
  maintenanceRequests  MaintenanceRequest[]
  company              Company                @relation(fields: [companyId], references: [id])
  landlord             Landlord?              @relation(fields: [landlordId], references: [id])
  tenants              Tenant[]
  units                Unit[]

  @@index([companyId])
  @@index([landlordId])
  @@index([deletedAt])
}

/// A rentable unit inside a property (e.g. Apartment 3B, Shop 12, Office Suite A).
model Unit {
  id                  String                 @id @default(uuid())
  unitNumber          String
  floor               String?
  bedrooms            Int?
  bathrooms           Int?
  sizeSqm             Float?
  rentAmount          Float?
  status              UnitStatus             @default(VACANT)
  propertyId          String
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  deletedAt           DateTime?
  semanticTags        String?
  embedding           Unsupported("vector")?
  documents           Document[]
  expenses            Expense[]
  leases              Lease[]
  maintenanceRequests MaintenanceRequest[]
  property            Property               @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([status])
  @@index([deletedAt])
}

/// A tenant — a person or business that rents space from a managed property.
/// "Tenant" here means the real-world renter, NOT the multi-tenant software concept.
model Tenant {
  id           String                 @id @default(uuid())
  firstName    String
  lastName     String
  email        String?
  phone        String?
  idNumber     String?
  companyId    String
  propertyId   String
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  deletedAt    DateTime?
  semanticTags String?
  embedding    Unsupported("vector")?
  language     String                 @default("en")
  documents    Document[]
  leases       Lease[]
  company      Company                @relation(fields: [companyId], references: [id])
  property     Property               @relation(fields: [propertyId], references: [id])

  @@index([companyId])
  @@index([propertyId])
  @@index([deletedAt])
}

/// A lease agreement linking a Tenant to a Unit for a period of time.
model Lease {
  id           String      @id @default(uuid())
  startDate    DateTime
  endDate      DateTime
  rentAmount   Float
  deposit      Float?
  status       LeaseStatus @default(PENDING)
  propertyId   String
  unitId       String?
  tenantId     String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
  semanticTags String?
  documents    Document[]
  invoices     Invoice[]
  property     Property    @relation(fields: [propertyId], references: [id])
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  unit         Unit?       @relation(fields: [unitId], references: [id])
  payments     Payment[]
  penalties    Penalty[]

  @@index([propertyId])
  @@index([unitId])
  @@index([tenantId])
  @@index([status])
  @@index([deletedAt])
}

/// A maintenance request / work order raised for a property or unit.
/// Tracks the full lifecycle from initial report through to resolution.
model MaintenanceRequest {
  id            String                 @id @default(uuid())
  title         String
  description   String?
  category      MaintenanceCategory    @default(GENERAL)
  priority      MaintenancePriority    @default(MEDIUM)
  status        MaintenanceStatus      @default(REPORTED)
  reportedAt    DateTime               @default(now())
  scheduledAt   DateTime?
  completedAt   DateTime?
  estimatedCost Float?
  actualCost    Float?
  vendor        String?
  vendorPhone   String?
  notes         String?
  companyId     String
  propertyId    String
  unitId        String?
  assignedToId  String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  deletedAt     DateTime?
  semanticTags  String?
  embedding     Unsupported("vector")?
  assignedTo    User?                  @relation(fields: [assignedToId], references: [id])
  company       Company                @relation(fields: [companyId], references: [id])
  property      Property               @relation(fields: [propertyId], references: [id])
  unit          Unit?                  @relation(fields: [unitId], references: [id])

  @@index([companyId])
  @@index([propertyId])
  @@index([unitId])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([deletedAt])
}

/// A payment made by a tenant against a lease.
model Payment {
  id        String        @id @default(uuid())
  amount    Float
  paidAt    DateTime      @default(now())
  method    PaymentMethod @default(MPESA)
  type      PaymentType   @default(RENT)
  reference String?
  notes     String?
  leaseId   String
  penaltyId String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
  incomes   Income[]
  lease     Lease         @relation(fields: [leaseId], references: [id])
  penalty   Penalty?      @relation(fields: [penaltyId], references: [id])

  @@index([leaseId])
  @@index([penaltyId])
  @@index([method])
  @@index([deletedAt])
}

/// An invoice issued against a lease for standard billing purposes.
model Invoice {
  id          String      @id @default(uuid())
  amount      Float
  description String
  dueDate     DateTime
  status      String      @default("PENDING")
  leaseId     String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  type        InvoiceType @default(RENT)
  deletedAt   DateTime?
  lease       Lease       @relation(fields: [leaseId], references: [id])

  @@index([leaseId])
  @@index([status])
  @@index([deletedAt])
}

/// A document file uploaded into the platform.
/// Scoped to a Company and optionally tied to a specific Property, Unit, Tenant, or Lease.
model Document {
  id          String       @id @default(uuid())
  name        String
  fileUrl     String
  type        DocumentType @default(OTHER)
  description String?
  companyId   String
  propertyId  String?
  unitId      String?
  tenantId    String?
  leaseId     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  company     Company      @relation(fields: [companyId], references: [id])
  lease       Lease?       @relation(fields: [leaseId], references: [id])
  property    Property?    @relation(fields: [propertyId], references: [id])
  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  unit        Unit?        @relation(fields: [unitId], references: [id])

  @@index([companyId])
  @@index([propertyId])
  @@index([unitId])
  @@index([tenantId])
  @@index([leaseId])
  @@index([deletedAt])
}

/// An expense incurred for maintaining or operating a property or unit.
/// Scoped to a Company, optionally tied to a specific Property or Unit.
model Expense {
  id          String          @id @default(uuid())
  description String
  amount      Float
  category    ExpenseCategory @default(OTHER)
  date        DateTime        @default(now())
  vendor      String?
  reference   String?
  notes       String?
  companyId   String
  propertyId  String?
  unitId      String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  company     Company         @relation(fields: [companyId], references: [id])
  property    Property?       @relation(fields: [propertyId], references: [id])
  unit        Unit?           @relation(fields: [unitId], references: [id])

  @@index([companyId])
  @@index([propertyId])
  @@index([category])
  @@index([deletedAt])
}

/// A penalty charged to a tenant — late payment fees, lease violations,
/// property damage charges, early termination fees, etc.
model Penalty {
  id          String        @id @default(uuid())
  type        PenaltyType   @default(LATE_PAYMENT)
  status      PenaltyStatus @default(PENDING)
  amount      Float
  description String?
  issuedAt    DateTime      @default(now())
  leaseId     String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  payments    Payment[]
  lease       Lease         @relation(fields: [leaseId], references: [id])

  @@index([leaseId])
  @@index([type])
  @@index([status])
  @@index([deletedAt])
}

model Invitation {
  id        String    @id @default(uuid())
  email     String
  role      UserRole  @default(COMPANY_STAFF)
  token     String    @unique
  companyId String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  firstName String?
  lastName  String?
  company   Company?  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([token])
}

model AuditLog {
  id             String                 @id @default(uuid())
  timestamp      DateTime               @default(now())
  action         String
  outcome        String
  method         String
  path           String
  entity         String?
  targetId       String?
  actorId        String?
  actorRole      String?
  actorCompanyId String?
  statusCode     Int?
  durationMs     Int?
  ip             String?
  userAgent      String?
  requestId      String?
  metadata       Json?
  embedding      Unsupported("vector")?
  semanticTags   String?

  @@index([timestamp(sort: Desc)])
  @@index([action])
  @@index([outcome])
  @@index([entity])
  @@index([actorId])
}

model WorkflowInstance {
  id        String         @id @default(uuid())
  type      WorkflowType
  status    WorkflowStatus @default(PENDING)
  companyId String
  userId    String?
  targetId  String?
  metadata  Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?
  company   Company        @relation(fields: [companyId], references: [id])
  steps     WorkflowStep[]

  @@index([companyId])
  @@index([type])
  @@index([status])
  @@index([deletedAt])
}

model WorkflowStep {
  id                 String           @id @default(uuid())
  workflowInstanceId String
  action             String
  fromStatus         WorkflowStatus
  toStatus           WorkflowStatus
  actorId            String?
  metadata           Json?
  timestamp          DateTime         @default(now())
  workflowInstance   WorkflowInstance @relation(fields: [workflowInstanceId], references: [id])

  @@index([workflowInstanceId])
}

/// A record of income for the managing company (e.g. commissions, fees).
model Income {
  id          String         @id @default(uuid())
  amount      Float
  category    IncomeCategory @default(COMMISSION)
  date        DateTime       @default(now())
  description String?
  companyId   String
  propertyId  String?
  paymentId   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
  company     Company        @relation(fields: [companyId], references: [id])
  payment     Payment?       @relation(fields: [paymentId], references: [id])
  property    Property?      @relation(fields: [propertyId], references: [id])

  @@index([companyId])
  @@index([propertyId])
  @@index([category])
  @@index([deletedAt])
}

model ChatHistory {
  id        String        @id @default(uuid())
  title     String?
  userId    String?
  companyId String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
  company   Company?      @relation(fields: [companyId], references: [id])
  user      User?         @relation(fields: [userId], references: [id])
  messages  ChatMessage[]

  @@index([userId])
  @@index([companyId])
  @@index([deletedAt])
}

model ChatMessage {
  id            String      @id @default(uuid())
  chatHistoryId String
  role          String
  content       String
  createdAt     DateTime    @default(now())
  feedbackNote  String?
  feedbackScore Int?
  chatHistory   ChatHistory @relation(fields: [chatHistoryId], references: [id])

  @@index([chatHistoryId])
}

model WhatsAppLog {
  id            String     @id @default(uuid())
  companyId     String?
  to            String
  templateName  String
  senderType    SenderType
  status        String
  metaMessageId String?
  createdAt     DateTime   @default(now())
  company       Company?   @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([to])
}

model WhatsAppProfile {
  phone     String   @id
  language  String?
  onboarded Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TodoItem {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TodoStatus @default(PENDING)
  dueDate     DateTime?
  isCritical  Boolean    @default(false)
  userId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  user        User       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model AuthorizationRequest {
  id          String              @id @default(uuid())
  actionType  String
  requestedBy String
  approverIds String[]
  status      AuthorizationStatus @default(PENDING)
  payload     Json
  companyId   String?
  expiresAt   DateTime
  executedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  company     Company?            @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([status])
}

/// Global user roles across the platform
enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  COMPANY_STAFF
  LANDLORD
  TENANT
  UNIDENTIFIED
}

/// Status of a lease
enum LeaseStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  PENDING
}

/// Status of a unit (vacancy tracking)
enum UnitStatus {
  VACANT
  OCCUPIED
  UNDER_MAINTENANCE
  VACATING
}

/// Type of property
enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  MIXED_USE
  INDUSTRIAL
  LAND
}

/// Category of an expense
enum ExpenseCategory {
  MAINTENANCE
  REPAIR
  UTILITY
  INSURANCE
  TAX
  MANAGEMENT_FEE
  LEGAL
  CLEANING
  SECURITY
  OTHER
  OFFICE_RENT
  INTERNET
  SALARY
  MARKETING
  OFFICE_SUPPLIES
  COMMISSION_AGENT_FEE
}

/// Type of penalty
enum PenaltyType {
  LATE_PAYMENT
  LEASE_VIOLATION
  PROPERTY_DAMAGE
  EARLY_TERMINATION
  OTHER
}

/// Status of a penalty
enum PenaltyStatus {
  PENDING
  PAID
  WAIVED
  PARTIALLY_PAID
}

/// Type of document uploaded to the platform
enum DocumentType {
  AGREEMENT
  COMPLIANCE
  ID_PROOF
  INVOICE_COPY
  OTHER
}

/// How a payment was made
enum PaymentMethod {
  MPESA
  BANK_TRANSFER
  CASH
  CHEQUE
  CARD
  OTHER
}

/// What the payment is for
enum PaymentType {
  RENT
  DEPOSIT
  PENALTY
  UTILITY
  OTHER
}

/// Type of invoice
enum InvoiceType {
  RENT
  MAINTENANCE
  PENALTY
  UTILITY
  OTHER
}

/// Status of a maintenance request
enum MaintenanceStatus {
  REPORTED
  ACKNOWLEDGED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

/// Priority level for maintenance
enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/// Category of maintenance work
enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  STRUCTURAL
  PAINTING
  APPLIANCE
  PEST_CONTROL
  HVAC
  ROOFING
  FLOORING
  GENERAL
  OTHER
}

enum WorkflowType {
  RENT_COLLECTION
  MAINTENANCE_LIFECYCLE
  LEASE_RENEWAL
  TENANT_ONBOARDING
  AUTONOMOUS_AGENT
}

enum WorkflowStatus {
  PENDING
  ACTIVE
  AWAITING_INPUT
  AWAITING_CONFIRMATION
  COMPLETED
  FAILED
  CANCELLED
  BACKGROUND_PAUSED
}

enum IncomeCategory {
  COMMISSION
  MANAGEMENT_FEE
  OTHER
}

enum SenderType {
  SYSTEM
  COMPANY
}

enum AuthorizationStatus {
  PENDING
  NOTIFIED
  QUORUM_MET
  REJECTED
  EXPIRED
  EXECUTED
}

enum TodoStatus {
  PENDING
  DONE
}
